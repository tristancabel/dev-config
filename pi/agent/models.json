{
  "providers": {
    "mistral": {
      "baseUrl": "https://codestral.mistral.ai/v1",
      "apikey": "${MISTRAL_SECRET}"
    }
  },
  "defaultModel": "mistral/codestral-latest",
  "defaultThinkingLevel": "medium",

  "routing": {
    "scout": {
      "provider": "mistral",
      "model": "codestral-latest",
      "thinkingLevel": "low"
    },
    "planner": {
      "provider": "mistral",
      "model": "codestral-latest",
      "thinkingLevel": "high"
    },
    "builder": {
      "provider": "mistral",
      "model": "codestral-latest",
      "thinkingLevel": "medium"
    },
    "reviewer": {
      "provider": "mistral",
      "model": "codestral-latest",
      "thinkingLevel": "high"
    },
    "verifier": {
      "provider": "mistral",
      "model": "codestral-latest",
      "thinkingLevel": "medium"
    }
  }
}
